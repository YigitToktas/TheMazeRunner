@{
    ViewData["Title"] = "Hakkinda";
}

<style>
    * {
        box-sizing:border-box;
    }

    html,body {
        height:100%;
        margin:0;
    }

    .card-img {
        position: absolute;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card {
        position: relative;
        height: 100vh;
        overflow: hidden;
    }

</style>

<div class="container-fluid p-0">
    <div class="card text-bg-dark">
        <img src="~/images/maze-oyuncular.jpg" class="card-img" style="filter:brightness(40%);">

        <div class="card-img-overlay m-auto text-center justify-content-center" style="padding-top:8rem !important;">

            <h4 class="card-title bebas" style="font-size:2rem;">HAKKIMIZDA</h4>
            <p class="card-text finlandica">
                Bu site, Labirent film serisini tanıtmak ve hayranlarına <br /> bilgi sunmak amacıyla hazırlanmıştır.Serinin <br />
                büyüleyici dünyasını keşfetmek için doğru yerdesiniz.
            </p>
            <br /> <br />
            <h4 class="card-title bebas" style="font-size:2rem;">İLETİŞİM</h4>
            <p class="card-text finlandica">
                Bu site, Labirent film serisini tanıtmak ve hayranlarına <br /> bilgi sunmak amacıyla hazırlanmıştır.Serinin <br />
                büyüleyici dünyasını keşfetmek için doğru yerdesiniz.
            </p>
            <div class="mx-auto w-50" style="max-width:100%;">
                <form>
                    <div class="mb-2">
                        <input type="text" class="form-control bg-dark text-light border-secondary" placeholder="Adınız">
                    </div>

                    <div class="mb-2">
                        <input type="email" class="form-control bg-dark text-light border-secondary" placeholder="E-posta">
                    </div>

                    <div class="mb-2">
                        <textarea class="form-control bg-dark text-light border-secondary" rows="4" placeholder="Mesajınız"></textarea>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn text-white" style="background-color: #3e4a24;">GÖNDER</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>