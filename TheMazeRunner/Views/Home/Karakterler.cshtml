@{
    ViewData["Title"] = "Karakterler";
}

<style>
    * {
        box-sizing: border-box;
    }

    body {
        background-color: #171717;
    }

    .golge_ve_parlaklık {
        filter:brightness(45%);
        transition:0.3s ease;
    }

    .golge_ve_parlaklık:hover {
        filter:brightness(100%);
            box-shadow: 0px 0px 41px #226907;
    }

    .karakter-kart {
        height: 310px;
        overflow: hidden;
        border-radius: 20px;
    }

        .karakter-kart img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .filmler-baslik h1 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 66px;
        letter-spacing: 6px;
        margin: auto;
    }

    .filmler-baslik p {
        margin: auto;
        font-size: 28px;
        letter-spacing: 3px;
        color: #7a9a52;
        font-family: 'Bebas Neue', sans-serif;
        text-shadow: 0px 0px 30px #226907;
    }

</style>

